{
  "name": "byu-photobooth-kiosk",
  "productName": "byU 포토부스",
  "version": "1.5.0",
  "description": "바이유포토랩 포토부스 키오스크 (설치형)",
  "main": "main.js",
  "author": "byU (바이유포토랩)",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "kr.byu.photobooth.kiosk",
    "productName": "byU 포토부스",
    "files": [
      "main.js",
      "preload.js",
      "app/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "byU 포토부스",
      "artifactName": "byU-PhotoBooth-Setup.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vmann0113",
        "repo": "byu_photolab",
        "releaseType": "release"
      }
    ]
  }
}
